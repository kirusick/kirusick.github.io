doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= `${personalInfo.name} — ${personalInfo.title}`

    style.
      :root {
        --text: #1f2937;
        --muted: #6b7280;
        --accent: #2563eb;
        --bg: #ffffff;
      }

      body {
        margin: 0;
        padding: 40px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
          Roboto, Inter, Helvetica, Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.55;
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
      }

      h1 {
        font-size: 36px;
        margin-bottom: 4px;
      }

      h2 {
        font-size: 20px;
        margin-top: 24px;
        margin-bottom: 12px;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 6px;
      }

      h3 {
        font-size: 18px;
        margin: 0;
      }

      .subtitle {
        font-size: 18px;
        color: var(--muted);
        margin-bottom: 12px;
      }

      .contact {
        font-size: 14px;
        color: var(--muted);
        margin-bottom: 32px;
      }

      .contact a {
        color: var(--accent);
        text-decoration: none;
      }

      p {
        margin: 8px 0;
      }

      ul {
        margin: 8px 0 16px 20px;
      }

      li {
        margin-bottom: 6px;
      }

      .job {
        margin-bottom: 28px;
      }

      .job ul {
        margin-top: 8px;
      }

      .job li {
        line-height: 1.5;
      }

      .job-header {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
      }

      .job-meta {
        font-size: 14px;
        color: var(--muted);
      }

      .skills {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 12px 24px;
        font-size: 14px;
      }

      .skills span {
        display: block;
      }

      .education {
        margin-bottom: 16px;
      }
      
      .avatar {
        width: 128px;
        height: 128px;
        border-radius: 50%;
      }

      header {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .non-breakable {
        white-space: nowrap;
      }

      @media print {
        body {
          padding: 20px;
        }
        .professional-summary h2 {
          margin-top: 12px;
        }
        .cv-pdf {
          display: none;
        }
        .page-break {
          padding-top: 140px;
        }
        .languages-section {
          padding-top: 40px;
        }
      }

      @media (max-width: 720px) {
        body {
          padding: 16px;
        }
        header {
          flex-direction: column;
          text-align: center;
          gap: 0px;
        }
        header h1 {
          margin-top: 12px;
        }
        .contact {
          margin-bottom: 0px;
        }
        ul {
          padding-inline-start: 12px;
        }
      }
  body
    .container
      header
        img.avatar(src=personalInfo.avatar)
        div
          h1= personalInfo.name
          .subtitle= personalInfo.title
          .contact
            | #{personalInfo.location} ·
            = ' '
            a(href=personalInfo.linkedin.url)= personalInfo.linkedin.text
            |  · 
            span.non-breakable Email: 
            a(href=`mailto:${personalInfo.email}`)=personalInfo.email
            |  · 
            a(href=personalInfo.github.url)= personalInfo.github.text
            span.cv-pdf  · 
            a.cv-pdf(href='./cv.pdf') CV.pdf

      section.professional-summary
        h2 Professional Summary
        p
          | Senior Frontend Developer with 
          strong 8+ years of commercial experience 
          | building scalable web applications using 
          strong React and TypeScript.
        p
          | Experienced in designing maintainable frontend architectures, improving application performance and building accessible user interfaces compliant with 
          strong WCAG standards.
        p
          | Strong background in enterprise environments, cross-team collaboration and mentoring developers. Passionate about building reliable, maintainable and high-quality frontend systems.

      section
        h2 Core Skills
        .skills
          each skill in skills
            span
              strong= `${skill.category}:`
              = ` ${skill.items}`

      section
        h2 Professional Experience
        each job in jobs
          .job
            .job-header
              h3= `${job.company} — ${job.title}`
              .job-meta= `${job.period} · ${job.location}`
            if job.responsibilities && job.responsibilities.length > 0
              ul
                each responsibility in job.responsibilities
                  li= responsibility

      div.page-break
      section.languages-section
        h2 Languages
        ul.languages
          each lang in languages
            li= `${lang.name} — ${lang.level}`

      section
        h2 Education
        each edu in education
          .education
            strong= edu.institution
            br
            = edu.degree
